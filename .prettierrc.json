{
  "semi": true,
  "trailingComma": "es5",
  "singleQuote": true,
  "printWidth": 100,
  "tabWidth": 2,
  "endOfLine": "auto",
  "plugins": ["@trivago/prettier-plugin-sort-imports"],
  "importOrder": [
    "^react",
    "^@?\\w",
    "^(@/components)(/.*)$",
    "^(@/lib)(/.*)$",
    "^\\./(?=.*/)(?!.*/style$)",
    "^\\.(?!.*/style$)",
    "^.+\\.module\\.(css|scss)$",
    "^.+\\.(png|gif|jpg|jpeg|svg)$"
  ],
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true
}
